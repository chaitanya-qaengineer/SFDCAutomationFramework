<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SFDC Automation Suite" verbose="1" parallel="none">

    <!-- ===================== -->
    <!-- SMOKE TEST SUITE      -->
    <!-- ===================== -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.CreateAccountTest"/>
            <class name="tests.OpportunitiesTest"/>
        </classes>
    </test>

    <!-- ===================== -->
    <!-- REGRESSION TEST SUITE -->
    <!-- ===================== -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.CreateAccountTest"/>
            <class name="tests.OpportunitiesTest"/>
            <class name="tests.UserMenuTest"/>
        </classes>
    </test>

</suite>
